{
  "UserPromptSubmit": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on_user_prompt.js",
          "timeout": 8
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on_stop.js",
          "timeout": 4
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on_session_end.js",
          "timeout": 6
        }
      ]
    }
  ]
}
